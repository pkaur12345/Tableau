      <column caption='Area Code1' datatype='string' hidden='true' name='[Area_Code]' role='dimension' type='nominal' />
      <column caption='Arrest Made' datatype='string' name='[Arrest_Made]' role='dimension' type='nominal' />
      <column caption='Clean Date' datatype='date' datatype-customized='true' name='[Calculation_1839815187062787]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF ISDATE([Date_Reported]) THEN &#13;&#10;    DATE([Date_Reported])&#13;&#10;&#13;&#10;ELSE &#13;&#10;    DATE(&#13;&#10;        IFNULL(&#13;&#10;            DATEPARSE(&quot;dd-MM-yyyy&quot;, [Date_Reported]),&#13;&#10;            IFNULL(&#13;&#10;                DATEPARSE(&quot;yyyy-MM-dd&quot;, [Date_Reported]),&#13;&#10;                DATEPARSE(&quot;MM/dd/yyyy&quot;, [Date_Reported])&#13;&#10;            )&#13;&#10;        )&#13;&#10;    )&#13;&#10;END' />
      </column>
      <column caption='Year' datatype='integer' datatype-customized='true' name='[Calculation_1839815189180420]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR([Calculation_1839815187062787])' />
      </column>
      <column caption='Month Name' datatype='string' name='[Calculation_1839815189684229]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;month&apos;, [Calculation_1839815187062787])' />
      </column>
      <column caption='Time Bucket' datatype='string' name='[Calculation_1839815189794822]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Hour] &lt; 6 THEN &quot;Night&quot;&#13;&#10;ELSEIF [Hour] &lt; 12 THEN &quot;Morning&quot;&#13;&#10;ELSEIF [Hour] &lt; 18 THEN &quot;Afternoon&quot;&#13;&#10;ELSE &quot;Evening&quot;&#13;&#10;END' />
      </column>
      <column caption='Day Type' datatype='string' name='[Calculation_1839815189987335]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEPART(&apos;weekday&apos;, [Calculation_1839815187062787]) IN (1,7) THEN &quot;Weekend&quot;&#13;&#10;ELSE &quot;Weekday&quot;&#13;&#10;END' />
      </column>
      <column caption='Age Group' datatype='string' name='[Calculation_1839815190077448]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Victim Age] &lt; 18 THEN &quot;Minor&quot;&#13;&#10;ELSEIF [Victim Age] &lt;= 35 THEN &quot;Young Adult&quot;&#13;&#10;ELSEIF [Victim Age] &lt;= 60 THEN &quot;Adult&quot;&#13;&#10;ELSE &quot;Senior&quot;&#13;&#10;END' />
      </column>
      <column caption='Case Outcome' datatype='string' name='[Calculation_1839815190188041]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS([Case Status], &quot;Closed&quot;) THEN &quot;Resolved&quot;&#13;&#10;ELSEIF CONTAINS([Case Status], &quot;Investigation&quot;) THEN &quot;Investigating&quot;&#13;&#10;ELSE &quot;Open&quot;&#13;&#10;END' />
      </column>
      <column caption='Weapon Category' datatype='string' name='[Calculation_1839815190331402]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS([Weapon Used], &quot;Gun&quot;) THEN &quot;Firearm&quot;&#13;&#10;ELSEIF CONTAINS([Weapon Used], &quot;Knife&quot;) THEN &quot;Sharp&quot;&#13;&#10;ELSEIF CONTAINS([Weapon Used], &quot;None&quot;) THEN &quot;No Weapon&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
      <column caption='Resolution Rate' datatype='real' name='[Calculation_1839815190478859]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;IF [Calculation_1839815190188041] = &quot;Resolved&quot; THEN 1 ELSE 0 END&#13;&#10;)' />
      </column>
      <column caption='Year Fixed' datatype='integer' name='[Calculation_1839815195287567]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(REPLACE(STR([Calculation_1839815189180420]), &quot;,&quot;, &quot;&quot;))' />
      </column>
      <column caption='Year Date' datatype='date' name='[Calculation_1839815195738128]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='MAKEDATE([Calculation_1839815195287567], 1, 1)' />
      </column>
      <column caption='MAX Year' datatype='string' name='[Calculation_1839815198662673]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF COUNTD([Case_ID]) = WINDOW_MAX(COUNTD([Case_ID])) &#13;&#10;THEN &quot;Peak&quot; &#13;&#10;ELSE &quot;Normal&quot; &#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Month Number' datatype='integer' name='[Calculation_1839815199924243]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEPART(&apos;month&apos;, [Calculation_1839815187062787])' />
      </column>
      <column caption='Above Avg Flag' datatype='string' name='[Calculation_1839815203459092]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF COUNTD([Case_ID]) &gt; WINDOW_AVG(COUNTD([Case_ID])) &#13;&#10;THEN &quot;Above Avg&quot; &#13;&#10;ELSE &quot;Below Avg&quot; &#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Total Crimes' datatype='integer' name='[Calculation_1839815208599575]' role='measure' type='quantitative'>
