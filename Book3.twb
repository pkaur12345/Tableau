    <worksheet name='Monthly Pattern'>
      <table>
        <view>
          <datasources>
            <datasource caption='final_realistic_dataset' name='federated.1bnoh9607viowp10eqg8a1ajgy2g' />
          </datasources>
          <datasource-dependencies datasource='federated.1bnoh9607viowp10eqg8a1ajgy2g'>
            <column caption='Clean Date' datatype='date' datatype-customized='true' name='[Calculation_1839815187062787]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='IF ISDATE([Date_Reported]) THEN &#13;&#10;    DATE([Date_Reported])&#13;&#10;&#13;&#10;ELSE &#13;&#10;    DATE(&#13;&#10;        IFNULL(&#13;&#10;            DATEPARSE(&quot;dd-MM-yyyy&quot;, [Date_Reported]),&#13;&#10;            IFNULL(&#13;&#10;                DATEPARSE(&quot;yyyy-MM-dd&quot;, [Date_Reported]),&#13;&#10;                DATEPARSE(&quot;MM/dd/yyyy&quot;, [Date_Reported])&#13;&#10;            )&#13;&#10;        )&#13;&#10;    )&#13;&#10;END' />
            </column>
            <column caption='Month Name' datatype='string' name='[Calculation_1839815189684229]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATENAME(&apos;month&apos;, [Calculation_1839815187062787])' />
            </column>
            <column caption='Month Number' datatype='integer' name='[Calculation_1839815199924243]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEPART(&apos;month&apos;, [Calculation_1839815187062787])' />
            </column>
            <column caption='Above Avg Flag' datatype='string' name='[Calculation_1839815203459092]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF COUNTD([Case_ID]) &gt; WINDOW_AVG(COUNTD([Case_ID])) &#13;&#10;THEN &quot;Above Avg&quot; &#13;&#10;ELSE &quot;Below Avg&quot; &#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Case ID' datatype='string' name='[Case_ID]' role='dimension' type='nominal' />
            <column caption='Date Reported' datatype='string' name='[Date_Reported]' role='dimension' type='nominal' />
            <column-instance column='[Case_ID]' derivation='CountD' name='[ctd:Case_ID:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1839815199924243]' derivation='Min' name='[min:Calculation_1839815199924243:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1839815189684229]' derivation='None' name='[none:Calculation_1839815189684229:nk]' pivot='key' type='nominal' />
